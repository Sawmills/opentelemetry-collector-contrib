apiVersion: batch/v1
kind: Job
metadata:
  name: queue-drain-loadgen
  namespace: queue-drain
spec:
  backoffLimit: 0
  template:
    metadata:
      labels:
        app: queue-drain-loadgen
    spec:
      restartPolicy: Never
      containers:
        - name: loadgen
          image: __LOADGEN_IMAGE__
          imagePullPolicy: IfNotPresent
          env:
            - name: MODE
              value: "loadgen"
            - name: OTLP_ENDPOINT
              value: "queue-drain-lb.queue-drain.svc.cluster.local:4317"
            - name: LOAD_DURATION
              value: "__LOAD_DURATION__"
            - name: LOAD_RATE
              value: "__LOAD_RATE__"
            - name: LOAD_WORKERS
              value: "__LOAD_WORKERS__"
            - name: BATCH_SIZE
              value: "__BATCH_SIZE__"
            - name: ALLOW_EXPORT_FAILURES
              value: "true"
            - name: SERVICE_NAME
              value: "customer-local-queue-drain"
            - name: TENANT
              value: "customer"
            - name: LOG_BODY
              value: "__LOG_BODY__"
            - name: PAYLOAD_PROFILE
              value: "__PAYLOAD_PROFILE__"
            - name: PAYLOAD_SIZE_BYTES
              value: "__PAYLOAD_SIZE_BYTES__"
            - name: PAYLOAD_RANDOM_SEED
              value: "__PAYLOAD_RANDOM_SEED__"
            - name: OTLP_COMPRESSION
              value: "__OTLP_COMPRESSION__"
